generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String   @id @default(uuid())
  email                 String   @unique
  name                  String?
  role                  String
  hashedPassword        String?
  emailVerified         DateTime?
  resetToken            String?
  resetTokenExpires     DateTime?
  image                 String?
  // relations required by NextAuth
  accounts              Account[]
  sessions              Session[]
  // connections relations
  connections           UserConnection[] @relation("connections")
  connectedTo           UserConnection[] @relation("connectedTo")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// models added for NextAuth functionality
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// events for the agenda
model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  type        String?
  createdAt   DateTime @default(now())
}

// user-to-user connections (many-to-many through this join table)
model UserConnection {
  id        String @id @default(uuid())
  userId    String
  targetId  String
  status    String @default("connected")

  user   User @relation("connections", fields: [userId], references: [id], onDelete: Cascade)
  target User @relation("connectedTo", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId])
}
