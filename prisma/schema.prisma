generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(uuid())
  email             String           @unique
  name              String?
  role              String
  hashedPassword    String?
  emailVerified     DateTime?
  resetToken        String?
  resetTokenExpires DateTime?
  image             String?
  // relations required by NextAuth
  accounts          Account[]
  sessions          Session[]
  // connections relations
  connections       UserConnection[] @relation("connections")
  connectedTo       UserConnection[] @relation("connectedTo")
  // other relations
  notifications     Notification[]
  ticketOrders      TicketOrder[]
  organization      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

// models added for NextAuth functionality
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// events for the agenda
model Event {
  id           String        @id @default(uuid())
  title        String
  description  String?
  date         DateTime
  type         String?
  createdAt    DateTime      @default(now())
  ticketOrders TicketOrder[]
}

// user-to-user connections (many-to-many through this join table)
model UserConnection {
  id       String @id @default(uuid())
  userId   String
  targetId String
  status   String @default("connected")

  user   User @relation("connections", fields: [userId], references: [id], onDelete: Cascade)
  target User @relation("connectedTo", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId])
}

// contact form submissions — persisted for admin review
// User.role can be: "youth" | "company" | "institution" | "mentor" | "sponsor" | "admin"
model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("unread") // "unread" | "read" | "replied"
  createdAt DateTime @default(now())
}

// in-app notifications (admin broadcasts + system alerts)
model Notification {
  id        String   @id @default(uuid())
  userId    String? // null = broadcast to all
  title     String
  message   String
  type      String   @default("info") // "info" | "warning" | "success" | "error"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ticket orders (persisted purchases)
model TicketOrder {
  id         String   @id @default(uuid())
  userId     String
  eventId    String? // linked event
  ticketType String // "standard" | "vip" | "student" | "virtual"
  quantity   Int      @default(1)
  price      Float
  total      Float
  status     String   @default("pending") // "pending" | "completed" | "failed" | "cancelled"
  qrCode     String   @unique @default(uuid()) // unique token encoded in QR
  createdAt  DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}
