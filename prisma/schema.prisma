generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(uuid())
  email             String           @unique
  name              String?
  role              String
  hashedPassword    String?
  emailVerified     DateTime?
  resetToken        String?
  resetTokenExpires DateTime?
  image             String?
  // relations required by NextAuth
  accounts          Account[]
  sessions          Session[]
  // connections relations
  connections       UserConnection[] @relation("connections")
  connectedTo       UserConnection[] @relation("connectedTo")
  // other relations
  notifications     Notification[]
  ticketOrders      TicketOrder[]
  organization      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  // partner/sponsor relation
  partner           Partner?
}

// models added for NextAuth functionality
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// events for the agenda
model Event {
  id           String        @id @default(uuid())
  title        String
  description  String?
  date         DateTime
  time         String? // Time field for the event (e.g. "14:00")
  location     String? // Location/Venue of the event
  type         String?
  price        Float? // Ticket price for this event
  phone_number String? // Contact phone number for the event
  createdAt    DateTime      @default(now())
  ticketOrders TicketOrder[]
}

// user-to-user connections (many-to-many through this join table)
model UserConnection {
  id       String @id @default(uuid())
  userId   String
  targetId String
  status   String @default("connected")

  user   User @relation("connections", fields: [userId], references: [id], onDelete: Cascade)
  target User @relation("connectedTo", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId])
}

// contact form submissions — persisted for admin review
// User.role can be: "youth" | "company" | "institution" | "mentor" | "sponsor" | "admin"
model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("unread") // "unread" | "read" | "replied"
  createdAt DateTime @default(now())
}

// in-app notifications (admin broadcasts + system alerts)
model Notification {
  id        String   @id @default(uuid())
  userId    String? // null = broadcast to all
  title     String
  message   String
  type      String   @default("info") // "info" | "warning" | "success" | "error"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ticket orders (persisted purchases)
model TicketOrder {
  id         String   @id @default(uuid())
  userId     String
  eventId    String? // linked event
  ticketType String // "standard" | "vip" | "student" | "virtual"
  quantity   Int      @default(1)
  price      Float // price per ticket (= event.price * quantity)
  total      Float // kept for backward compat (same as price)
  reference  String? // optional payment reference (e.g. 1133223564476)
  status     String   @default("pending") // "pending" | "completed" | "failed" | "cancelled"
  qrCode     String   @unique @default(uuid()) // unique token encoded in QR
  createdAt  DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

// ─── Partner / Sponsor Management ────────────────────────────────────────────

model Partner {
  id      String  @id @default(uuid())
  name    String
  slug    String  @unique
  logo    String?
  website String?
  email   String?
  phone   String?

  category String // "tech" | "finance" | "education" | "ngo" | "government" | "other"
  type     String @default("PARTNER") // "PARTNER" | "SPONSOR"
  status   String @default("ACTIVE") // "ACTIVE" | "INACTIVE" | "PENDING"

  tagline     String?
  description String?
  vision      String?
  impact      String?
  locations   String[] @default([])

  // Optional link to a User account with role="sponsor"
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunities  PartnerOpportunity[]
  testimonials   PartnerTestimonial[]
  sponsorPackage SponsorPackage?
  applications   SponsorApplication[]
}

model PartnerOpportunity {
  id          String   @id @default(uuid())
  partnerId   String
  title       String
  description String?
  level       String? // "Entry Level" | "Student" | "All Levels"
  type        String? // "internship" | "job" | "scholarship" | "mentorship"
  createdAt   DateTime @default(now())

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

model PartnerTestimonial {
  id        String   @id @default(uuid())
  partnerId String
  quote     String
  author    String
  role      String?
  createdAt DateTime @default(now())

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

model SponsorPackage {
  id          String    @id @default(uuid())
  partnerId   String    @unique
  packageType String // "INSTITUTIONAL" | "IMPACT" | "INNOVATION" | "PREMIUM"
  budget      Float?
  startDate   DateTime?
  endDate     DateTime?
  benefits    String[]  @default([])
  notes       String?

  partner   Partner           @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  analytics SponsorAnalytics?
}

model SponsorApplication {
  id                  String   @id @default(uuid())
  companyName         String
  contactName         String
  email               String
  phone               String?
  jobTitle            String?
  sponsorshipInterest String?
  budget              String?
  message             String?
  status              String   @default("PENDING") // "PENDING" | "REVIEWED" | "ACCEPTED" | "REJECTED" | "COMPLETED"
  partnerId           String?
  createdAt           DateTime @default(now())

  partner Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
}

model SponsorAnalytics {
  id                String   @id @default(uuid())
  packageId         String   @unique
  boothVisits       Int      @default(0)
  impressions       Int      @default(0)
  clicks            Int      @default(0)
  leads             Int      @default(0)
  conversions       Int      @default(0)
  socialMentions    Int      @default(0)
  videoViews        Int      @default(0)
  downloadsMaterial Int      @default(0)
  ctr               Float    @default(0)
  roi               Float    @default(0)
  engagement        Float    @default(0)
  updatedAt         DateTime @updatedAt

  package      SponsorPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  sponsorLeads SponsorLead[]
}

model SponsorLead {
  id           String   @id @default(uuid())
  analyticsId  String
  name         String
  email        String
  organization String?
  interested   Boolean  @default(false)
  createdAt    DateTime @default(now())

  analytics SponsorAnalytics @relation(fields: [analyticsId], references: [id], onDelete: Cascade)
}
